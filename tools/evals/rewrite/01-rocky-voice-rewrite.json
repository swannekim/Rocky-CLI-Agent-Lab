{
  "id": "rewrite-01-rocky-voice-rewrite",
  "title": "Rocky-style rewrite for study overwhelm",
  "prompt_file": "prompts/05-rewrite-rocky-voice.md",
  "suggested_output_file": "tools/evals/outputs/rewrite-01-rocky-voice-rewrite.txt",
  "checks": {
    "case_insensitive": true,
    "min_nonempty_lines": 3,
    "max_nonempty_lines": 10,
    "required_line_prefixes": [
      "Core idea",
      "Next action"
    ],
    "required_any_of": [
      ["overwhelmed", "too much", "too many things", "study"],
      ["small step", "one topic", "today", "now"]
    ],
    "max_occurrences": {
      "question?": 2,
      "AMAZE": 1
    },
    "banned_substrings": [
      "as an ai",
      "language model"
    ]
  }
}
